<script>
// ── STATE ──
const state = {
  trends: [],
  scripts: [],
  queue: [],
  currentScript: null,
  scriptCount: 0,
  settings: {
    ytKey: '',
    antKey: '',
    vpsUrl: '',
    scriptLen: 150,
    refreshInterval: 30
  }
};

// ── INIT ──
window.addEventListener('load', () => {
  loadSettings();
  setTimeout(() => {
    document.getElementById('splash').classList.add('hide');
    document.getElementById('app').classList.add('show');
    loadTrends();
  }, 2800);
});

// ── TABS ──
function showTab(tab) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('panel-' + tab).classList.add('active');
  document.querySelectorAll('.nav-tab').forEach(t => {
    if (t.textContent.toLowerCase().trim() === tab) t.classList.add('active');
  });
}

// ── SETTINGS ──
function loadSettings() {
  const s = JSON.parse(localStorage.getItem('awys-settings') || '{}');
  Object.assign(state.settings, s);
  if (s.ytKey) document.getElementById('yt-key').value = s.ytKey;
  if (s.antKey) document.getElementById('ant-key').value = s.antKey;
  if (s.vpsUrl) document.getElementById('vps-url').value = s.vpsUrl;
  if (s.scriptLen) document.getElementById('script-len').value = s.scriptLen;
  if (s.refreshInterval) document.getElementById('refresh-interval').value = s.refreshInterval;
}

function saveSettings() {
  state.settings.ytKey = document.getElementById('yt-key').value.trim();
  state.settings.antKey = document.getElementById('ant-key').value.trim();
  state.settings.vpsUrl = document.getElementById('vps-url').value.trim();
  state.settings.scriptLen = parseInt(document.getElementById('script-len').value) || 150;
  state.settings.refreshInterval = parseInt(document.getElementById('refresh-interval').value) || 30;
  localStorage.setItem('awys-settings', JSON.stringify(state.settings));
  showToast('Settings saved');
}

// ── TRENDS ──
async function loadTrends() {
  document.getElementById('trends-container').innerHTML =
    '<div class="empty"><div class="empty-text">Loading trends<span class="loading-dots"></span></div></div>';

  const key = state.settings.ytKey;
  if (!key) {
    showSampleTrends();
    return;
  }

  try {
    const res = await fetch(
      `https://www.googleapis.com/youtube/v3/videos?part=snippet,statistics&chart=mostPopular&videoCategoryId=0&maxResults=12&regionCode=US&key=${key}`
    );
    const data = await res.json();
    if (data.error) { showSampleTrends(); return; }

    state.trends = data.items.map(item => ({
      id: item.id,
      title: item.snippet.title,
      channel: item.snippet.channelTitle,
      views: parseInt(item.statistics.viewCount || 0),
      platform: 'YouTube',
      thumbnail: item.snippet.thumbnails?.default?.url
    }));

    document.getElementById('stat-topics').textContent = state.trends.length;
    document.getElementById('stat-yt').textContent = state.trends.length;
    document.getElementById('stat-gt').textContent = '10';
    renderTrends();
  } catch(e) {
    showSampleTrends();
  }
}

function showSampleTrends() {
  state.trends = [
    { title: 'AI tools changing everything in 2026', platform: 'YouTube', views: 2400000, hot: true },
    { title: 'Morning routine that actually works', platform: 'YouTube', views: 1800000, hot: true },
    { title: 'Why nobody talks about this money hack', platform: 'YouTube', views: 3100000, hot: true },
    { title: '5 things to do before 8am', platform: 'Google Trends', views: 900000, hot: false },
    { title: 'The truth about passive income', platform: 'YouTube', views: 2200000, hot: true },
    { title: 'This AI just replaced 10 jobs', platform: 'Google Trends', views: 1600000, hot: true },
    { title: 'One habit that changed my life', platform: 'YouTube', views: 1100000, hot: false },
    { title: 'How to go viral in 2026', platform: 'Google Trends', views: 780000, hot: false },
    { title: 'Investing when you have no money', platform: 'YouTube', views: 2900000, hot: true },
    { title: 'The AI sleep trick everyone is using', platform: 'Google Trends', views: 1400000, hot: true },
  ];
  document.getElementById('stat-topics').textContent = state.trends.length;
  document.getElementById('stat-yt').textContent = '6';
  document.getElementById('stat-gt').textContent = '4';
  renderTrends();
}

function renderTrends() {
  const container = document.getElementById('trends-container');
  if (!state.trends.length) {
    container.innerHTML = '<div class="empty"><div class="empty-text">No trends found</div></div>';
    return;
  }
  container.innerHTML = state.trends.map((t, i) => `
    <div class="trend-card">
      <div class="trend-platform">${t.platform}</div>
      <div class="trend-title">${t.title}</div>
      <div class="trend-meta">
        <span class="trend-views">${formatNum(t.views)} views</span>
        <span class="trend-badge ${t.hot ? 'hot' : ''}">${t.hot ? 'Trending' : 'Rising'}</span>
      </div>
      <button class="trend-generate" onclick="prefillScript('${t.title.replace(/'/g,"\\'")}')">
        Generate Script →
      </button>
    </div>
  `).join('');
}

function formatNum(n) {
  if (n >= 1000000) return (n/1000000).toFixed(1) + 'M';
  if (n >= 1000) return (n/1000).toFixed(0) + 'K';
  return n.toString();
}

// ── SCRIPTS ──
function prefillScript(topic) {
  showTab('scripts');
  document.getElementById('script-topic').value = topic;
  document.getElementById('script-topic').focus();
}

document.querySelectorAll('.chip').forEach(chip => {
  chip.addEventListener('click', () => {
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
    chip.classList.add('active');
  });
});

async function generateScript() {
  const topic = document.getElementById('script-topic').value.trim();
  if (!topic) { showToast('Enter a topic first'); return; }

  const platform = document.querySelector('.chip.active')?.dataset.platform || 'youtube';
  const btn = document.getElementById('gen-btn');
  btn.disabled = true;
  btn.textContent = 'Generating...';

  const key = state.settings.antKey;
  const len = state.settings.scriptLen || 150;

  const platformGuide = {
    youtube: 'YouTube Shorts (60 seconds, hook in first 3 seconds, strong CTA)',
    tiktok: 'TikTok (15-60 seconds, fast-paced, trending audio suggestion)',
    instagram: 'Instagram Reels (30-60 seconds, visually descriptive)',
    facebook: 'Facebook Reels (60 seconds, broader audience appeal)'
  };

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-api-key': key, 'anthropic-version': '2023-06-01' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        messages: [{
          role: 'user',
          content: `Write a ${platformGuide[platform]} script about: "${topic}".

Format:
HOOK: (first line — must grab attention instantly)
SCRIPT: (the main content, ~${len} words, conversational and engaging)
CTA: (call to action — subscribe/follow/like)
TAGS: (5 relevant hashtags)

Keep it punchy, modern, and optimized for virality. Write as if a confident creator is speaking directly to camera.`
        }]
      })
    });

    const data = await res.json();
    const text = data.content?.[0]?.text || 'Error generating script. Check your API key in Settings.';

    const script = {
      id: Date.now(),
      topic,
      platform,
      body: text,
      status: 'ready',
      created: new Date().toLocaleDateString()
    };

    state.scripts.unshift(script);
    state.scriptCount++;
    document.getElementById('stat-scripts').textContent = state.scriptCount;
    renderScripts();

    state.currentScript = script;
    openModal(script);

  } catch(e) {
    showToast('Error — check API key in Settings');
  }

  btn.disabled = false;
  btn.textContent = 'Generate';
}

function renderScripts() {
  const container = document.getElementById('scripts-container');
  if (!state.scripts.length) {
    container.innerHTML = '<div class="empty"><div class="empty-text">No scripts yet</div></div>';
    return;
  }
  container.innerHTML = state.scripts.map(s => `
    <div class="script-card">
      <div class="script-header">
        <div class="script-topic">${s.topic}</div>
        <div class="script-status ${s.status}">${s.status}</div>
      </div>
      <div class="script-body">${s.body}</div>
      <div class="script-actions">
        <button class="script-btn primary" onclick="viewScript(${s.id})">View</button>
        <button class="script-btn" onclick="addScriptToQueue(${s.id})">Queue</button>
        <button class="script-btn" onclick="copyScriptById(${s.id})">Copy</button>
      </div>
    </div>
  `).join('');
}

// ── MODAL ──
function openModal(script) {
  state.currentScript = script;
  document.getElementById('modal-title').textContent = script.platform.toUpperCase() + ' — ' + script.topic;
  document.getElementById('modal-script').textContent = script.body;
  document.getElementById('script-modal').classList.add('show');
}

function viewScript(id) {
  const s = state.scripts.find(s => s.id === id);
  if (s) openModal(s);
}

function closeModal() {
  document.getElementById('script-modal').classList.remove('show');
}

function copyScript() {
  if (state.currentScript) {
    navigator.clipboard.writeText(state.currentScript.body);
    showToast('Copied to clipboard');
  }
}

function copyScriptById(id) {
  const s = state.scripts.find(s => s.id === id);
  if (s) { navigator.clipboard.writeText(s.body); showToast('Copied'); }
}

// ── QUEUE ──
function addToQueue() {
  if (!state.currentScript) return;
  addScriptToQueue(state.currentScript.id);
  closeModal();
}

function addScriptToQueue(id) {
  const s = state.scripts.find(s => s.id === id);
  if (!s) return;
  const item = {
    id: Date.now(),
    scriptId: id,
    topic: s.topic,
    platform: s.platform,
    time: 'Scheduled',
    status: 'pending'
  };
  state.queue.unshift(item);
  s.status = 'posted';
  renderScripts();
  renderQueue();
  showToast('Added to queue');
}

function renderQueue() {
  const container = document.getElementById('queue-container');
  if (!state.queue.length) {
    container.innerHTML = '<div class="empty"><div class="empty-text">Queue is empty</div></div>';
    return;
  }
  container.innerHTML = state.queue.map(q => `
    <div class="queue-item">
      <div class="queue-time">${q.time}</div>
      <div class="queue-topic">${q.topic}</div>
      <div class="queue-platform">${q.platform}</div>
      <button class="queue-remove" onclick="removeFromQueue(${q.id})">Remove</button>
    </div>
  `).join('');
}

function removeFromQueue(id) {
  state.queue = state.queue.filter(q => q.id !== id);
  renderQueue();
}

// ── ANALYTICS ──
function loadAnalytics() {
  showToast('Analytics will populate as accounts connect');
}

// ── TOAST ──
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

// ── CLOSE MODAL ON OVERLAY ──
document.getElementById('script-modal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});
</script>
