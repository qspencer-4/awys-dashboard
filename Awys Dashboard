<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AWYS — AI While You Sleeping</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Raleway:wght@100;200;300;400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #000000;
    --white: #ffffff;
    --gold: #C9A020;
    --gold-dim: rgba(201,160,32,0.4);
    --gold-faint: rgba(201,160,32,0.08);
    --white-dim: rgba(255,255,255,0.45);
    --white-faint: rgba(255,255,255,0.08);
    --white-border: rgba(255,255,255,0.1);
    --surface: rgba(255,255,255,0.03);
    --surface-hover: rgba(255,255,255,0.06);
    --danger: #C97850;
    --success: #6BAF8A;
    --font-main: 'Raleway', sans-serif;
    --font-mono: 'Space Mono', monospace;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: var(--font-main);
    font-weight: 300;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── SPLASH ── */
  #splash {
    position: fixed; inset: 0;
    background: #000;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    z-index: 9999;
    transition: opacity 0.8s ease;
  }
  #splash.hide { opacity: 0; pointer-events: none; }
  .splash-a {
    font-family: var(--font-main);
    font-weight: 200;
    font-size: 140px;
    color: #fff;
    line-height: 1;
    letter-spacing: -4px;
    animation: splashPulse 2s ease infinite alternate;
  }
  .splash-sub {
    font-size: 11px;
    letter-spacing: 10px;
    color: rgba(255,255,255,0.35);
    margin-top: 16px;
    font-weight: 200;
  }
  .splash-gold { color: var(--gold); opacity: 0.8; }
  @keyframes splashPulse {
    from { opacity: 0.7; } to { opacity: 1; }
  }
  .splash-bar {
    width: 120px; height: 1px;
    background: rgba(255,255,255,0.1);
    margin-top: 40px;
    position: relative; overflow: hidden;
  }
  .splash-bar::after {
    content: '';
    position: absolute; left: -100%; top: 0;
    width: 100%; height: 100%;
    background: var(--gold);
    animation: splashLoad 2.5s ease forwards;
  }
  @keyframes splashLoad {
    from { left: -100%; } to { left: 0%; }
  }

  /* ── LAYOUT ── */
  #app { display: none; flex-direction: column; min-height: 100vh; }
  #app.show { display: flex; }

  /* ── HEADER ── */
  header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 32px;
    border-bottom: 1px solid var(--white-border);
    position: sticky; top: 0; z-index: 100;
    background: rgba(0,0,0,0.92);
    backdrop-filter: blur(12px);
  }
  .header-brand {
    display: flex; align-items: baseline; gap: 12px;
  }
  .header-a {
    font-size: 28px; font-weight: 200;
    letter-spacing: -1px; color: #fff;
  }
  .header-name {
    font-size: 10px; font-weight: 200;
    letter-spacing: 8px; color: var(--white-dim);
    text-transform: uppercase;
  }
  .header-version {
    font-family: var(--font-mono);
    font-size: 10px; color: var(--gold);
    opacity: 0.6; cursor: pointer;
    transition: opacity 0.2s;
  }
  .header-version:hover { opacity: 1; }

  /* ── NAV ── */
  nav {
    display: flex; gap: 0;
    border-bottom: 1px solid var(--white-border);
    padding: 0 32px;
    overflow-x: auto;
  }
  nav::-webkit-scrollbar { display: none; }
  .nav-tab {
    padding: 14px 20px;
    font-size: 11px; font-weight: 300;
    letter-spacing: 6px;
    color: var(--white-dim);
    cursor: pointer;
    border-bottom: 1px solid transparent;
    transition: all 0.2s;
    white-space: nowrap;
    text-transform: uppercase;
    margin-bottom: -1px;
    background: none; border-top: none; border-left: none; border-right: none;
  }
  .nav-tab:hover { color: var(--white); }
  .nav-tab.active {
    color: var(--white);
    border-bottom-color: var(--gold);
  }

  /* ── MAIN ── */
  main { flex: 1; padding: 40px 32px; max-width: 1400px; width: 100%; margin: 0 auto; }

  /* ── PANELS ── */
  .panel { display: none; animation: fadeUp 0.3s ease; }
  .panel.active { display: block; }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── SECTION HEADER ── */
  .section-header {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: 32px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--white-border);
  }
  .section-title {
    font-size: 11px; font-weight: 200;
    letter-spacing: 8px; color: var(--white-dim);
    text-transform: uppercase;
  }
  .section-action {
    font-size: 11px; font-weight: 300;
    letter-spacing: 4px; color: var(--gold);
    cursor: pointer; background: none; border: none;
    text-transform: uppercase;
    transition: opacity 0.2s;
  }
  .section-action:hover { opacity: 0.7; }

  /* ── STAT CARDS ── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1px;
    border: 1px solid var(--white-border);
    margin-bottom: 40px;
  }
  .stat-card {
    padding: 28px 24px;
    background: var(--surface);
    transition: background 0.2s;
  }
  .stat-card:hover { background: var(--surface-hover); }
  .stat-label {
    font-size: 9px; letter-spacing: 6px;
    color: var(--white-dim); text-transform: uppercase;
    margin-bottom: 12px; font-weight: 300;
  }
  .stat-value {
    font-size: 36px; font-weight: 100;
    color: var(--white); line-height: 1;
    font-family: var(--font-main);
  }
  .stat-value.gold { color: var(--gold); }
  .stat-delta {
    font-size: 10px; font-family: var(--font-mono);
    color: var(--success); margin-top: 8px;
  }
  .stat-delta.down { color: var(--danger); }

  /* ── TREND CARDS ── */
  .trends-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1px;
  }
  .trend-card {
    background: var(--surface);
    padding: 24px;
    border: 1px solid var(--white-border);
    transition: background 0.2s, border-color 0.2s;
    cursor: pointer;
  }
  .trend-card:hover {
    background: var(--surface-hover);
    border-color: rgba(255,255,255,0.2);
  }
  .trend-platform {
    font-size: 9px; letter-spacing: 5px;
    color: var(--gold); text-transform: uppercase;
    margin-bottom: 10px; font-weight: 300;
  }
  .trend-title {
    font-size: 15px; font-weight: 300;
    color: var(--white); line-height: 1.4;
    margin-bottom: 12px;
  }
  .trend-meta {
    display: flex; gap: 16px; align-items: center;
  }
  .trend-views {
    font-family: var(--font-mono);
    font-size: 11px; color: var(--white-dim);
  }
  .trend-badge {
    font-size: 9px; letter-spacing: 3px;
    padding: 3px 8px;
    border: 1px solid var(--white-border);
    color: var(--white-dim);
    text-transform: uppercase;
  }
  .trend-badge.hot {
    border-color: var(--gold-dim);
    color: var(--gold);
  }
  .trend-generate {
    margin-top: 16px;
    font-size: 10px; letter-spacing: 5px;
    color: var(--gold-dim);
    text-transform: uppercase;
    background: none; border: none;
    cursor: pointer; padding: 0;
    transition: color 0.2s;
    font-family: var(--font-main);
    font-weight: 300;
  }
  .trend-generate:hover { color: var(--gold); }

  /* ── SCRIPTS ── */
  .scripts-list { display: flex; flex-direction: column; gap: 1px; }
  .script-card {
    background: var(--surface);
    border: 1px solid var(--white-border);
    padding: 28px;
    transition: background 0.2s;
  }
  .script-card:hover { background: var(--surface-hover); }
  .script-header {
    display: flex; justify-content: space-between;
    align-items: flex-start; margin-bottom: 16px;
  }
  .script-topic {
    font-size: 14px; font-weight: 300;
    color: var(--white); line-height: 1.4;
    max-width: 70%;
  }
  .script-status {
    font-size: 9px; letter-spacing: 4px;
    text-transform: uppercase; padding: 4px 10px;
    border: 1px solid;
  }
  .script-status.draft { border-color: var(--white-border); color: var(--white-dim); }
  .script-status.ready { border-color: var(--gold-dim); color: var(--gold); }
  .script-status.posted { border-color: rgba(107,175,138,0.4); color: var(--success); }
  .script-body {
    font-size: 13px; color: var(--white-dim);
    line-height: 1.8; margin-bottom: 20px;
    font-weight: 300;
    display: -webkit-box; -webkit-line-clamp: 3;
    -webkit-box-orient: vertical; overflow: hidden;
  }
  .script-actions { display: flex; gap: 20px; }
  .script-btn {
    font-size: 10px; letter-spacing: 5px;
    color: var(--white-dim); text-transform: uppercase;
    background: none; border: none; cursor: pointer;
    transition: color 0.2s; font-family: var(--font-main);
    font-weight: 300; padding: 0;
  }
  .script-btn:hover { color: var(--white); }
  .script-btn.primary { color: var(--gold); }
  .script-btn.primary:hover { color: var(--white); }

  /* ── GENERATE FORM ── */
  .generate-box {
    border: 1px solid var(--white-border);
    padding: 32px;
    margin-bottom: 40px;
    background: var(--surface);
  }
  .generate-box textarea {
    width: 100%; background: none; border: none;
    border-bottom: 1px solid var(--white-border);
    color: var(--white); font-family: var(--font-main);
    font-weight: 300; font-size: 14px;
    padding: 12px 0; resize: none; outline: none;
    line-height: 1.6;
  }
  .generate-box textarea::placeholder { color: var(--white-dim); }
  .generate-row {
    display: flex; justify-content: space-between;
    align-items: center; margin-top: 20px;
  }
  .platform-chips { display: flex; gap: 8px; flex-wrap: wrap; }
  .chip {
    font-size: 9px; letter-spacing: 4px;
    padding: 6px 12px; border: 1px solid var(--white-border);
    color: var(--white-dim); cursor: pointer;
    text-transform: uppercase;
    transition: all 0.2s; font-family: var(--font-main);
    font-weight: 300; background: none;
  }
  .chip:hover, .chip.active {
    border-color: var(--gold);
    color: var(--gold);
  }
  .gen-btn {
    font-size: 10px; letter-spacing: 6px;
    color: var(--black); background: var(--white);
    border: none; padding: 12px 28px;
    cursor: pointer; text-transform: uppercase;
    font-family: var(--font-main); font-weight: 300;
    transition: background 0.2s, color 0.2s;
  }
  .gen-btn:hover { background: var(--gold); }
  .gen-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  /* ── ACCOUNTS ── */
  .accounts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1px;
  }
  .account-card {
    background: var(--surface);
    border: 1px solid var(--white-border);
    padding: 28px;
    transition: background 0.2s;
  }
  .account-card:hover { background: var(--surface-hover); }
  .account-platform {
    font-size: 9px; letter-spacing: 5px;
    text-transform: uppercase; color: var(--gold);
    margin-bottom: 10px; font-weight: 300;
  }
  .account-handle {
    font-size: 18px; font-weight: 200;
    color: var(--white); margin-bottom: 20px;
  }
  .account-stats { display: flex; gap: 24px; margin-bottom: 20px; }
  .account-stat-val {
    font-size: 22px; font-weight: 100; color: var(--white);
  }
  .account-stat-lbl {
    font-size: 9px; letter-spacing: 4px;
    color: var(--white-dim); text-transform: uppercase;
    margin-top: 4px;
  }
  .account-status {
    display: flex; align-items: center; gap: 8px;
    font-size: 10px; letter-spacing: 3px;
    color: var(--white-dim); text-transform: uppercase;
  }
  .status-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--success);
  }
  .status-dot.disconnected { background: var(--danger); }
  .status-dot.pending { background: var(--gold); }

  /* ── QUEUE ── */
  .queue-list { display: flex; flex-direction: column; gap: 1px; }
  .queue-item {
    display: grid;
    grid-template-columns: 100px 1fr auto auto;
    gap: 24px; align-items: center;
    background: var(--surface);
    border: 1px solid var(--white-border);
    padding: 20px 28px;
    transition: background 0.2s;
  }
  .queue-item:hover { background: var(--surface-hover); }
  .queue-time {
    font-family: var(--font-mono);
    font-size: 11px; color: var(--white-dim);
  }
  .queue-topic {
    font-size: 13px; font-weight: 300; color: var(--white);
  }
  .queue-platform {
    font-size: 9px; letter-spacing: 4px;
    color: var(--gold); text-transform: uppercase;
  }
  .queue-remove {
    font-size: 10px; letter-spacing: 3px;
    color: var(--white-dim); background: none;
    border: none; cursor: pointer;
    text-transform: uppercase; font-family: var(--font-main);
    transition: color 0.2s;
  }
  .queue-remove:hover { color: var(--danger); }

  /* ── ANALYTICS ── */
  .analytics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1px; margin-bottom: 40px;
  }
  .analytics-card {
    background: var(--surface);
    border: 1px solid var(--white-border);
    padding: 28px;
  }
  .analytics-title {
    font-size: 9px; letter-spacing: 6px;
    color: var(--gold); text-transform: uppercase;
    margin-bottom: 20px; font-weight: 300;
  }
  .chart-bars {
    display: flex; align-items: flex-end;
    gap: 6px; height: 80px; margin-bottom: 12px;
  }
  .bar {
    flex: 1; background: var(--white-faint);
    transition: background 0.2s; cursor: pointer;
    min-height: 4px;
  }
  .bar:hover { background: rgba(201,160,32,0.3); }
  .bar.active { background: var(--gold-dim); }
  .chart-labels {
    display: flex; gap: 6px;
  }
  .chart-label {
    flex: 1; font-size: 8px;
    font-family: var(--font-mono);
    color: var(--white-dim);
    text-align: center;
  }
  .analytics-row {
    display: flex; justify-content: space-between;
    align-items: center; padding: 12px 0;
    border-bottom: 1px solid var(--white-faint);
  }
  .analytics-row:last-child { border-bottom: none; }
  .analytics-label {
    font-size: 11px; color: var(--white-dim); font-weight: 300;
  }
  .analytics-val {
    font-family: var(--font-mono);
    font-size: 12px; color: var(--white);
  }
  .analytics-val.up { color: var(--success); }
  .analytics-val.down { color: var(--danger); }

  /* ── REVENUE ── */
  .revenue-total {
    padding: 48px 0;
    border-bottom: 1px solid var(--white-border);
    margin-bottom: 40px;
  }
  .revenue-label {
    font-size: 10px; letter-spacing: 8px;
    color: var(--white-dim); text-transform: uppercase;
    margin-bottom: 12px;
  }
  .revenue-amount {
    font-size: 72px; font-weight: 100;
    color: var(--white); line-height: 1;
  }
  .revenue-amount span { color: var(--gold); }
  .revenue-period {
    font-size: 11px; color: var(--white-dim);
    margin-top: 8px; letter-spacing: 3px;
  }

  /* ── CHANGELOG ── */
  .changelog-list { display: flex; flex-direction: column; }
  .changelog-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 32px;
    padding: 24px 0;
    border-bottom: 1px solid var(--white-faint);
  }
  .changelog-item:last-child { border-bottom: none; }
  .changelog-version {
    font-family: var(--font-mono);
    font-size: 11px; color: var(--gold);
    padding-top: 2px;
  }
  .changelog-content {}
  .changelog-date {
    font-size: 9px; letter-spacing: 4px;
    color: var(--white-dim); text-transform: uppercase;
    margin-bottom: 8px;
  }
  .changelog-changes { list-style: none; }
  .changelog-changes li {
    font-size: 13px; font-weight: 300;
    color: var(--white-dim); line-height: 1.8;
    padding-left: 16px; position: relative;
  }
  .changelog-changes li::before {
    content: '—';
    position: absolute; left: 0;
    color: var(--gold); opacity: 0.5;
  }

  /* ── SETTINGS ── */
  .settings-section { margin-bottom: 40px; }
  .settings-section-title {
    font-size: 9px; letter-spacing: 6px;
    color: var(--gold); text-transform: uppercase;
    margin-bottom: 16px; font-weight: 300;
  }
  .settings-row {
    display: flex; justify-content: space-between;
    align-items: center; padding: 18px 0;
    border-bottom: 1px solid var(--white-faint);
  }
  .settings-label {
    font-size: 13px; color: var(--white); font-weight: 300;
  }
  .settings-sub {
    font-size: 11px; color: var(--white-dim);
    margin-top: 2px;
  }
  .settings-input {
    background: var(--surface);
    border: 1px solid var(--white-border);
    color: var(--white); font-family: var(--font-mono);
    font-size: 11px; padding: 10px 16px;
    outline: none; width: 340px;
    transition: border-color 0.2s;
  }
  .settings-input:focus { border-color: var(--gold); }
  .settings-save {
    font-size: 10px; letter-spacing: 5px;
    color: var(--black); background: var(--white);
    border: none; padding: 10px 24px;
    cursor: pointer; text-transform: uppercase;
    font-family: var(--font-main); font-weight: 300;
    transition: background 0.2s;
    margin-top: 24px;
  }
  .settings-save:hover { background: var(--gold); }

  /* ── MODAL ── */
  .modal-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.9);
    display: flex; align-items: center; justify-content: center;
    z-index: 500; opacity: 0; pointer-events: none;
    transition: opacity 0.2s;
    backdrop-filter: blur(8px);
  }
  .modal-overlay.show { opacity: 1; pointer-events: all; }
  .modal {
    background: #0a0a0a;
    border: 1px solid var(--white-border);
    padding: 40px;
    width: 90%; max-width: 640px;
    max-height: 80vh; overflow-y: auto;
  }
  .modal-title {
    font-size: 10px; letter-spacing: 8px;
    color: var(--gold); text-transform: uppercase;
    margin-bottom: 24px;
  }
  .modal-script {
    font-size: 14px; font-weight: 300;
    color: var(--white); line-height: 2;
    white-space: pre-wrap;
  }
  .modal-close {
    margin-top: 32px;
    font-size: 10px; letter-spacing: 5px;
    color: var(--white-dim); background: none;
    border: none; cursor: pointer;
    text-transform: uppercase;
    font-family: var(--font-main);
    transition: color 0.2s;
  }
  .modal-close:hover { color: var(--white); }
  .loading-dots::after {
    content: '...';
    animation: dots 1.2s steps(4, end) infinite;
  }
  @keyframes dots {
    0%, 20% { content: ''; }
    40% { content: '.'; }
    60% { content: '..'; }
    80%, 100% { content: '...'; }
  }

  /* ── EMPTY STATE ── */
  .empty {
    padding: 80px 0; text-align: center;
  }
  .empty-text {
    font-size: 11px; letter-spacing: 6px;
    color: var(--white-dim); text-transform: uppercase;
  }

  /* ── TOAST ── */
  #toast {
    position: fixed; bottom: 32px; right: 32px;
    background: var(--white); color: var(--black);
    font-size: 11px; letter-spacing: 4px;
    text-transform: uppercase; padding: 14px 24px;
    z-index: 9999; opacity: 0;
    transition: opacity 0.3s; pointer-events: none;
    font-family: var(--font-main); font-weight: 300;
  }
  #toast.show { opacity: 1; }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 4px; height: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--white-border); }

  @media (max-width: 768px) {
    header { padding: 16px 20px; }
    main { padding: 24px 20px; }
    nav { padding: 0 20px; }
    .nav-tab { padding: 14px 14px; letter-spacing: 4px; }
    .queue-item { grid-template-columns: 1fr; gap: 8px; }
    .settings-input { width: 100%; }
    .settings-row { flex-direction: column; align-items: flex-start; gap: 12px; }
    .revenue-amount { font-size: 48px; }
  }
</style>
</head>
<body>

<!-- SPLASH -->
<div id="splash">
  <div class="splash-a">A</div>
  <div class="splash-sub">AI WHILE YOU <span class="splash-gold">SLEEPING</span></div>
  <div class="splash-bar"></div>
</div>

<!-- TOAST -->
<div id="toast"></div>

<!-- APP -->
<div id="app">
  <header>
    <div class="header-brand">
      <div class="header-a">A</div>
      <div class="header-name">AI While You Sleeping</div>
    </div>
    <div class="header-version" onclick="showTab('changelog')">v0.01</div>
  </header>

  <nav>
    <button class="nav-tab active" onclick="showTab('trends')">Trends</button>
